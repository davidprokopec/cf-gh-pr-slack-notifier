# Cloudflare API Token
# Required for SST to deploy to Cloudflare Workers
# Scopes needed: Workers Scripts Edit, Workers KV Storage Edit, Workers R2 Storage Edit, Account Settings Read
# Get it from: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your-token-here

# Cloudflare Account ID
# Required for SST to deploy to Cloudflare Workers
# Find it in your Cloudflare dashboard URL: https://dash.cloudflare.com/{ACCOUNT_ID}
CLOUDFLARE_DEFAULT_ACCOUNT_ID=your-account-id-here

# Slack Bot User OAuth Token
# Required to post and update messages in Slack
# Scopes needed: chat:write, users:list
# Get it from: https://api.slack.com/apps > Your App > OAuth & Permissions > Bot User OAuth Token
# Token format: starts with xoxb-
SLACK_BOT_TOKEN=xoxb-your-token-here

# GitHub Webhook Secret
# Random string used to verify webhook signatures from GitHub
# Generate with: openssl rand -hex 32
# Must match the secret configured in GitHub webhook settings
GITHUB_WEBHOOK_SECRET=your-random-secret-here

# Config API Key
# API key for runtime configuration management endpoints (/config, /clear-cache)
# Generate with: openssl rand -hex 32
# Required for all config API requests (x-api-key header)
CONFIG_API_KEY=your-api-key-here

# Custom Domain (optional)
# Custom domain for the Cloudflare Worker
# If not set, the worker will use the default *.workers.dev URL
# Example: pr-notifier.yourdomain.com
CUSTOM_DOMAIN=
